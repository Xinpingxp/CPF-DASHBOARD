# Copy this file to .env and fill in your values.
# IMPORTANT: Never commit .env to version control.

# ── Required ──────────────────────────────────────────────────────────────────
VITE_API_KEY=lol

# ── Provider (default: anthropic) ─────────────────────────────────────────────
# Options: anthropic | openrouter | openai
VITE_API_PROVIDER=anthropic

# ── Model override (optional) ─────────────────────────────────────────────────
# Leave blank to use the provider default.
# Anthropic default  : claude-opus-4-6
# OpenRouter default : anthropic/claude-opus-4   (any OR model works, e.g. openai/gpt-4o)
# OpenAI default     : gpt-4o
# VITE_API_MODEL=

# ── MongoDB ───────────────────────────────────────────────────────────────────
# Get this from MongoDB Atlas → Connect → Drivers
# Format: mongodb+srv://<user>:<password>@<cluster>.mongodb.net/<dbname>?retryWrites=true&w=majority
MONGODB_URI=

# ── Backend server port (optional, default 3001) ──────────────────────────────
PORT=3001

# ── Examples by provider ──────────────────────────────────────────────────────
# Anthropic:    VITE_API_KEY=sk-ant-...    VITE_API_PROVIDER=anthropic
# OpenRouter:   VITE_API_KEY=sk-or-...     VITE_API_PROVIDER=openrouter
# OpenAI:       VITE_API_KEY=sk-...        VITE_API_PROVIDER=openai
